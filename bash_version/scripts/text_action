#!/usr/bin/osascript -l JavaScript

function envVar(varName) {
  var val = $.NSProcessInfo.processInfo.environment.objectForKey(varName)
  return val ? val.js : ""
}

function safetySettings() {
  var threshold = envVar("safety_threshold") || "BLOCK_MEDIUM_AND_ABOVE"
  var categories = ["HARM_CATEGORY_HARASSMENT", "HARM_CATEGORY_HATE_SPEECH", "HARM_CATEGORY_SEXUALLY_EXPLICIT", "HARM_CATEGORY_DANGEROUS_CONTENT"]
  var result = []
  for (var i = 0; i < categories.length; i++) {
    result.push({ category: categories[i], threshold: threshold })
  }
  return result
}

function getAction(name) {
  var defaults = {
    explain: "You are an expert explainer. When given text, provide a clear and structured explanation.\n" +
      "- Identify the core concept or topic first.\n" +
      "- Break down complex ideas into digestible parts.\n" +
      "- Use analogies or examples when helpful.\n" +
      "- If the text contains code, explain what it does step by step.\n" +
      "- If the text is in a specific domain (legal, medical, technical), explain any jargon.\n" +
      "- Respond in the same language as the input text.",

    fix_grammar: "You are a professional editor and proofreader.\n" +
      "- Fix all spelling, grammar, and punctuation errors.\n" +
      "- Maintain the original meaning, tone, and style.\n" +
      "- Preserve the original language (do not translate).\n" +
      "- Keep proper nouns, brand names, and technical terms unchanged.\n" +
      "- Fix awkward phrasing or sentence structure where needed.\n" +
      "- Output ONLY the corrected text. No explanations or annotations.",

    make_shorter: "You are a concise editor.\n" +
      "- Reduce the text length by 40-60% while preserving the core message.\n" +
      "- Remove redundancies, filler words, and unnecessary qualifiers.\n" +
      "- Keep key facts, data, and important details.\n" +
      "- Maintain the original tone and language.\n" +
      "- Preserve paragraph structure when the text has multiple points.\n" +
      "- Output ONLY the shortened text.",

    make_longer: "You are an expressive writer.\n" +
      "- Expand the text by 50-100% with meaningful additions.\n" +
      "- Add relevant examples, context, or supporting details.\n" +
      "- Enhance descriptions and explanations.\n" +
      "- Do NOT add filler or repeat the same idea in different words.\n" +
      "- Maintain the original tone, style, and language.\n" +
      "- Output ONLY the expanded text.",

    tone_friendly: "You are a tone editor specializing in friendly communication.\n" +
      "- Rewrite the text in a warm, approachable, conversational tone.\n" +
      "- Use casual but professional language.\n" +
      "- Add appropriate softeners (e.g., 'I think', 'maybe', 'feel free to').\n" +
      "- Replace harsh or blunt phrasing with gentler alternatives.\n" +
      "- Keep the original meaning and key information intact.\n" +
      "- Maintain the original language.\n" +
      "- Output ONLY the rewritten text.",

    tone_professional: "You are a tone editor specializing in professional communication.\n" +
      "- Rewrite the text in a formal, polished, and authoritative tone.\n" +
      "- Use precise and clear language appropriate for business contexts.\n" +
      "- Remove colloquialisms, slang, and overly casual expressions.\n" +
      "- Ensure proper sentence structure and logical flow.\n" +
      "- Keep the original meaning and key information intact.\n" +
      "- Maintain the original language.\n" +
      "- Output ONLY the rewritten text.",

    add_comments: "You are a senior software engineer specializing in code documentation.\n" +
      "- Add clear, helpful inline comments to the code.\n" +
      "- Explain the 'why' behind logic, not just the 'what'.\n" +
      "- Add function/method docstrings explaining parameters, return values, and purpose.\n" +
      "- Use the appropriate comment syntax for the detected programming language.\n" +
      "- Do NOT modify the code logic itself.\n" +
      "- Keep comments concise — one line where possible.\n" +
      "- Output ONLY the commented code.",

    find_synonym: "You are a language expert and thesaurus.\n" +
      "- Identify all significant words in the text (skip articles, prepositions, common conjunctions).\n" +
      "- For each word, provide 3-5 synonyms ranked by relevance.\n" +
      "- Include the part of speech (noun, verb, adjective, etc.).\n" +
      "- If the text is in a non-English language, provide synonyms in that same language.\n" +
      "- Format: **word** (part of speech) → synonym1, synonym2, synonym3",

    summarize: "You are an expert summarizer.\n" +
      "- Provide a concise summary capturing all key points.\n" +
      "- Start with a one-sentence TL;DR.\n" +
      "- Then list the main points as bullet points.\n" +
      "- Include any critical data, numbers, or conclusions.\n" +
      "- Omit examples and repetitive details.\n" +
      "- Respond in the same language as the input text."
  }

  if (!defaults[name]) return null

  var customPrompt = envVar("prompt_" + name)
  var system = customPrompt || defaults[name]

  return { system: system }
}

function run(argv) {
  var actionName = envVar("action_name") || argv[0] || ""
  var text = argv[1] || argv[0] || ""

  if (envVar("action_name") !== "") {
    text = argv[0] || ""
  }

  if (text === "") return JSON.stringify({ response: "No text provided." })

  var apiKey = envVar("api_key")
  if (apiKey === "") return JSON.stringify({ response: "Error: API key not configured." })

  var action = getAction(actionName)
  if (!action) return JSON.stringify({ response: "Unknown action: " + actionName })

  var model = envVar("custom_model") || envVar("default_model") || "gemini-2.5-flash"
  var url = "https://generativelanguage.googleapis.com/v1beta/models/" + model + ":generateContent?key=" + apiKey

  var body = JSON.stringify({
    system_instruction: { parts: [{ text: action.system }] },
    contents: [{ role: "user", parts: [{ text: text }] }],
    safetySettings: safetySettings()
  })

  var task = $.NSTask.alloc.init
  var pipe = $.NSPipe.pipe
  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/curl")
  task.arguments = [url, "--silent", "--max-time", "60", "--header", "Content-Type: application/json", "--data", body]
  task.standardOutput = pipe
  task.launchAndReturnError(false)
  task.waitUntilExit

  var data = pipe.fileHandleForReading.readDataToEndOfFile
  var responseStr = $.NSString.alloc.initWithDataEncoding(data, $.NSUTF8StringEncoding).js

  try {
    var response = JSON.parse(responseStr)
    if (response.error) return JSON.stringify({ response: "Error: " + response.error.message })
    var result = response.candidates[0].content.parts[0].text
    return JSON.stringify({ response: result.trim() })
  } catch (e) {
    return JSON.stringify({ response: "Error parsing response: " + responseStr.substring(0, 200) })
  }
}
